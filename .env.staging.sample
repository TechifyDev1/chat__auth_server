# Krabby Chat Auth Server - Environment Configuration Example

# App Environment
# Options: development, staging, production
APP__ENV=development

# Server Configuration
APP__SERVER__HOST=127.0.0.1
APP__SERVER__PORT=8000
APP__SERVER__REQUEST_TIMEOUT_SECS=30

# Database Configuration
# NOTE: Ensure the connection URL matches your local setup
DATABASE_URL=postgres://user:password@localhost:5433/database_name
APP__DATABASE__ENGINE=postgres
APP__DATABASE__MAX_CONNECTIONS=10

# Auth Configuration
# Used for JWT signing - USE A SECURE KEY IN PRODUCTION
APP__AUTH__JWT_SECRET=yoursecretkeyhere
APP__AUTH__JWT_EXPIRATION_LIFETIME_SECS=3600
APP__AUTH__REFRESH_TOKEN_EXPIRATION_LIFETIME_SECS=86400
